<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>JEE Blog</display-name>

    <!-- Encodage UTF-8 pour toutes les requêtes -->
    <filter>
        <filter-name>encodageFilter</filter-name>
        <filter-class>com.blog.filter.LangueFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>encodageFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Filtre CSRF - valide les tokens sur les POST -->
    <filter>
        <filter-name>csrfFilter</filter-name>
        <filter-class>com.blog.filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>csrfFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Filtre d'authentification -->
    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.blog.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/articles/nouveau</url-pattern>
        <url-pattern>/articles/modifier</url-pattern>
        <url-pattern>/articles/supprimer</url-pattern>
        <url-pattern>/commentaires/*</url-pattern>
        <url-pattern>/profil</url-pattern>
        <url-pattern>/profil/*</url-pattern>
        <url-pattern>/messages</url-pattern>
        <url-pattern>/notifications</url-pattern>
        <url-pattern>/collection</url-pattern>
        <url-pattern>/collection/*</url-pattern>
        <url-pattern>/like</url-pattern>
        <url-pattern>/follow</url-pattern>
    </filter-mapping>

    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Pages d'erreur -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/erreur-404.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/jsp/erreur-403.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/erreur-404.jsp</location>
    </error-page>

    <!-- Configuration session : 30 minutes -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
