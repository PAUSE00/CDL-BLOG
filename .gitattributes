# JEE Blog - Git Attributes
# Normalize line endings across platforms

# Default behavior: auto-detect text files, normalize to LF in repo
* text=auto

# Java files
*.java text eol=lf
*.properties text eol=lf
*.xml text eol=lf

# Web files
*.jsp text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# SQL
*.sql text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Binary files
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
